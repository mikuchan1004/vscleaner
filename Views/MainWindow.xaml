<Window x:Class="VSCleaner.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:VSCleaner.ViewModels"
        Title="VSCleaner" 
        Height="500" Width="700"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResize" Icon="/cleaner.ico">

    <Window.Resources>
        <Style x:Key="ModernButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#FFE1E1E1"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="Padding" Value="15,7"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Style.Resources>
                <Style TargetType="Border">
                    <Setter Property="CornerRadius" Value="4"/>
                </Style>
            </Style.Resources>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#FFD5D5D5"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#FFBBBBBB"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="AccentButtonStyle" TargetType="Button" BasedOn="{StaticResource ModernButtonStyle}">
            <Setter Property="Background" Value="#FF007ACC"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#FF005A9E"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#FF004578"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Window.DataContext>
        <vm:MainViewModel />
    </Window.DataContext>

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <DockPanel Grid.Row="0" Margin="0,0,0,15">
            <Button Content="폴더 선택 및 스캔" 
                    Command="{Binding ScanCommand}" 
                    Style="{StaticResource ModernButtonStyle}"
                    DockPanel.Dock="Left"/>
            <TextBlock Text="{Binding SelectedPath}" 
                       VerticalAlignment="Center" 
                       Margin="15,0,0,0" 
                       Foreground="#FF666666"
                       FontSize="12"
                       TextTrimming="CharacterEllipsis"/>
        </DockPanel>

        <ListBox Grid.Row="1" ItemsSource="{Binding TargetFolders}" 
                 HorizontalContentAlignment="Stretch"
                 BorderBrush="#FFDDDDDD" BorderThickness="1">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Grid Margin="0,3">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="100"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="{Binding FormattedSize}" 
                                   FontWeight="SemiBold" HorizontalAlignment="Right" 
                                   Margin="0,0,15,0" Foreground="#FF007ACC"/>
                        <TextBlock Grid.Column="1" Text="{Binding Path}" 
                                   Foreground="#FF444444" TextTrimming="CharacterEllipsis"/>
                    </Grid>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <Button Grid.Row="2" Content="청소 시작" 
                Command="{Binding ClearCommand}" 
                Style="{StaticResource AccentButtonStyle}"
                Margin="0,15,0,5" Padding="0,12" FontSize="14"/>

        <StatusBar Grid.Row="3" Background="#FFF0F0F0" Margin="0,5,0,0">
            <StatusBarItem>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="상태: " Foreground="Gray"/>
                    <TextBlock Text="{Binding StatusMessage}" FontWeight="Medium"/>
                </StackPanel>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>